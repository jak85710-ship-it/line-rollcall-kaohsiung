# Server
PORT=3000
BASE_URL=https://your-app.onrender.com

# LINE Messaging API
LINE_CHANNEL_ID=your_channel_id
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret

# LINE LIFF
LIFF_ID=your_liff_id

# Coach authorization (comma-separated LINE User IDs)
COACH_LINE_USER_IDS=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin panel login password
ADMIN_TOKEN=12345

# Google Sheets API
# 試算表網址中的 ID：https://docs.google.com/spreadsheets/d/【這段就是ID】/edit
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id
# 從 Google Cloud 服務帳戶 JSON 金鑰取得
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# 私鑰請保留 \n 換行（用雙引號包住整段）
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email - Gmail 應用程式密碼
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-digit-app-password
EMAIL_FROM=運動隊點名系統 <your-email@gmail.com>
EMAIL_TO=coach@school.edu.tw
